{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "std-d-db-audit-rating-vs-main-audit-type",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "totalRecords",
    "meta",
    "overallPerformanceDistribution",
    "clusterLevelPerformance",
    "auditeeTypeAnalysis",
    "auditeeLevelHotspots"
  ],
  "properties": {
    "totalRecords": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of distinct schedules included in this widget payload."
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generatedAt",
        "source",
        "ratingLabels",
        "topLimit"
      ],
      "properties": {
        "generatedAt": {
          "type": "string",
          "description": "Payload generation timestamp in ISO-8601 format."
        },
        "source": {
          "type": "string",
          "description": "Source API or transformer identifier."
        },
        "ratingLabels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Distinct audit rating buckets represented across sections."
        },
        "topLimit": {
          "type": "integer",
          "minimum": 1,
          "description": "Cap used for the top-N auditeeLevelHotspots list."
        }
      }
    },
    "overallPerformanceDistribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "totalSchedules",
        "ratingDistribution"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "totalSchedules": {
          "type": "integer",
          "minimum": 0
        },
        "ratingDistribution": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/ratingDistributionItem"
          }
        }
      }
    },
    "clusterLevelPerformance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "totalClusters",
        "items"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "totalClusters": {
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/clusterPerformanceItem"
          }
        }
      }
    },
    "auditeeTypeAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "totalAuditeeTypes",
        "items"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "totalAuditeeTypes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total distinct auditee type categories (e.g. Branch, Regional Office, Corporate Office, Warehouse)."
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/auditeeTypePerformanceItem"
          }
        }
      }
    },
    "auditeeLevelHotspots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "topLimit",
        "items"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "topLimit": {
          "type": "integer",
          "minimum": 1
        },
        "items": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "$ref": "#/definitions/auditeeHotspotItem"
          }
        }
      }
    }
  },
  "definitions": {
    "ratingDistributionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auditRating",
        "scheduleCount",
        "percentOfTotal"
      ],
      "properties": {
        "auditRating": {
          "type": "string"
        },
        "scheduleCount": {
          "type": "integer",
          "minimum": 0
        },
        "percentOfTotal": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "scoreValue": {
      "description": "Average achieved score. Empty string signals non-computable metric.",
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        {
          "type": "string",
          "enum": [
            ""
          ]
        }
      ]
    },
    "clusterPerformanceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clusterName",
        "scheduleCount",
        "averageAchievedScore",
        "issueCount",
        "ratingDistribution"
      ],
      "properties": {
        "clusterName": {
          "type": "string"
        },
        "scheduleCount": {
          "type": "integer",
          "minimum": 0
        },
        "averageAchievedScore": {
          "$ref": "#/definitions/scoreValue"
        },
        "issueCount": {
          "type": "integer",
          "minimum": 0
        },
        "ratingDistribution": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ratingDistributionItem"
          }
        }
      }
    },
    "auditeeTypePerformanceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auditeeType",
        "scheduleCount",
        "averageAchievedScore",
        "issueCount",
        "ratingDistribution"
      ],
      "properties": {
        "auditeeType": {
          "type": "string",
          "description": "Category of the entity being audited (e.g. Branch, Regional Office, Corporate Office, Warehouse, School). NOT the named audit template."
        },
        "scheduleCount": {
          "type": "integer",
          "minimum": 0
        },
        "averageAchievedScore": {
          "$ref": "#/definitions/scoreValue"
        },
        "issueCount": {
          "type": "integer",
          "minimum": 0
        },
        "ratingDistribution": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ratingDistributionItem"
          }
        }
      }
    },
    "auditeeHotspotItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auditeeName",
        "auditeeType",
        "clusterName",
        "scheduleCount",
        "averageAchievedScore",
        "issueCount",
        "ratingDistribution"
      ],
      "properties": {
        "auditeeName": {
          "type": "string"
        },
        "auditeeType": {
          "type": "string"
        },
        "clusterName": {
          "type": "string"
        },
        "scheduleCount": {
          "type": "integer",
          "minimum": 0
        },
        "averageAchievedScore": {
          "$ref": "#/definitions/scoreValue"
        },
        "issueCount": {
          "type": "integer",
          "minimum": 0
        },
        "ratingDistribution": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ratingDistributionItem"
          }
        }
      }
    }
  }
}
